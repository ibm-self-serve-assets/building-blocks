# IBM Concert API Configuration
# Copy this file to .env and fill in your actual values

# IBM Concert Base URL (without trailing slash)
CONCERT_BASE_URL=https://your-concert-instance.ibm.com

# IBM Concert API Key (literal "C_API_KEY" prefix will be added automatically)
C_API_KEY=your_api_key_here

# IBM Concert Instance ID
INSTANCE_ID=your_instance_id_here

# Application Configuration
DEBUG_MODE=False
HOST=127.0.0.1
PORT=8050

# API Configuration
API_TIMEOUT=30
API_PAGE_LIMIT=100