# =============================================================================
# RAG Ingestion MCP Server - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# This server ingests documents from IBM Cloud Object Storage (COS) or local
# directories into OpenSearch for RAG applications

# =============================================================================
# Server Configuration
# =============================================================================
HOST=0.0.0.0
PORT=8080

SERVER_NAME=rag-ingestion-mcp
SERVER_VERSION=1.0.0

SERVER_DESCRIPTION=Base MCP Server for Data for AI Building Block (with RAG ingestion)

ENVIRONMENT=development

PUBLIC_BASE_URL=

ALLOWED_HOSTS=

ALLOWED_ORIGINS=

APP_BEARER_TOKEN=

LOG_LEVEL=INFO

# =============================================================================
# IBM Cloud Object Storage (COS) Configuration
# =============================================================================
COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud

COS_API_KEY=your_cos_api_key_here

# Format: crn:v1:bluemix:public:cloud-object-storage:global:a/<account_id>:<instance_id>::
COS_INSTANCE_CRN=crn:v1:bluemix:public:cloud-object-storage:global:a/your_account_id:your_instance_id::

COS_BUCKET=your_bucket_name

COS_PREFIX=ingest

# =============================================================================
# IBM watsonx.ai Embeddings Configuration (REQUIRED)
# =============================================================================
IBM_API_KEY=your_ibm_cloud_api_key_here

WATSONX_URL=https://us-south.ml.cloud.ibm.com

WATSONX_PROJECT_ID=your_project_id_here

# Recommended: ibm/slate-125m-english-rtrvr
EMBEDDING_MODEL_ID=ibm/slate-125m-english-rtrvr

# =============================================================================
# Document Chunking Configuration
# =============================================================================
CHUNK_SIZE=256

CHUNK_OVERLAP=128

INCLUDE_ALL_HTML_TAGS=false

# =============================================================================
# Vector Database Selection (REQUIRED)
# =============================================================================
# Only opensearch is supported
VECTOR_DB_TYPE=opensearch

# =============================================================================
# OpenSearch Configuration (REQUIRED)
# =============================================================================
OPENSEARCH_HOST=your_opensearch_host_here

OPENSEARCH_PORT=9200

OPENSEARCH_USERNAME=your_opensearch_username

OPENSEARCH_PASSWORD=your_opensearch_password

OPENSEARCH_INDEX=rag-index

OPENSEARCH_USE_SSL=true
