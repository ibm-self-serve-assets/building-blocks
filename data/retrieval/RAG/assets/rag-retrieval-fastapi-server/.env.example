# =============================================================================
# RAG Retrieval FastAPI Server - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# This server provides REST API endpoints for hybrid search and keyword search

# =============================================================================
# Server Configuration
# =============================================================================
HOST=0.0.0.0
PORT=8080

SERVER_NAME=rag-retrieval-api
SERVER_VERSION=1.0.0

SERVER_DESCRIPTION=FastAPI RAG Retrieval Server for hybrid and keyword search

ENVIRONMENT=development

ALLOWED_ORIGINS=*

APP_BEARER_TOKEN=

# =============================================================================
# IBM watsonx.ai Embeddings (REQUIRED)
# =============================================================================
IBM_API_KEY=your_ibm_cloud_api_key_here

WATSONX_URL=https://us-south.ml.cloud.ibm.com

WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Recommended: ibm/slate-125m-english-rtrvr (must match model used during ingestion)
EMBEDDING_MODEL_ID=ibm/slate-125m-english-rtrvr

# =============================================================================
# Vector Database Selection (REQUIRED)
# =============================================================================
# Only opensearch is supported
VECTOR_DB_TYPE=opensearch

# =============================================================================
# OpenSearch Configuration (REQUIRED)
# =============================================================================
# IBM watsonx.data OpenSearch host
OPENSEARCH_HOST=your-opensearch-host.databases.appdomain.cloud

OPENSEARCH_PORT=9200

OPENSEARCH_USERNAME=your_opensearch_username

OPENSEARCH_PASSWORD=your_opensearch_password

# Index name to search (must match the index used during ingestion)
OPENSEARCH_INDEX=rag-index

OPENSEARCH_USE_SSL=true
