# ============================================================
# watsonx.data OpenSearch – Data Ingestion Service
# ============================================================

# IBM Cloud Authentication
IBM_API_KEY=your_ibm_cloud_api_key
IBM_IAM_URL=https://iam.cloud.ibm.com/identity/token

# IBM watsonx.ai (for embeddings)
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=your_watsonx_project_id
EMBEDDING_MODEL_ID=ibm/slate-125m-english-rtrvr

# IBM Cloud Object Storage (document source)
COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
COS_API_KEY=your_cos_api_key
COS_INSTANCE_CRN=crn:v1:bluemix:public:cloud-object-storage:global:a/ACCOUNT_ID:RESOURCE_GUID::
COS_BUCKET=your-documents-bucket

# IBM watsonx.data OpenSearch
OPENSEARCH_HOST=your-opensearch-host.databases.appdomain.cloud
OPENSEARCH_PORT=30628
OPENSEARCH_USER=ibm_cloud_user
OPENSEARCH_PASSWORD=your_opensearch_password
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_CA_CERTS=

# Chunking configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=128
INDEX_CHUNK_BATCH_SIZE=256

# REST API security key
REST_API_KEY=your_rest_api_key
SERVER_URL=http://0.0.0.0:8080
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
