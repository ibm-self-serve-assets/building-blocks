# ============================================================
# DataStax Astra DB – NoSQL CRUD Service
# IBM Cloud portfolio: HCD (Hyper-Converged Database) / AstraDB
# ============================================================

# DataStax Astra DB
ASTRA_DB_API_ENDPOINT=https://XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX-us-east1.apps.astra.datastax.com
ASTRA_DB_APPLICATION_TOKEN=AstraCS:your_application_token
ASTRA_DB_KEYSPACE=default_keyspace

# REST API key for this service
REST_API_KEY=your_rest_api_key
SERVER_URL=http://0.0.0.0:8080
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
