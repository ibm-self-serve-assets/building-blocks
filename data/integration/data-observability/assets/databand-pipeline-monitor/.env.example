# ============================================================
# IBM Databand Pipeline Monitor – Environment Configuration
# ============================================================

# IBM Cloud Authentication
IBM_API_KEY=your_ibm_cloud_api_key
IBM_IAM_URL=https://iam.cloud.ibm.com/identity/token

# IBM Databand Instance
DATABAND_URL=https://your-instance.databand.ai
# Personal access token from Databand UI → Account → Access Tokens
DATABAND_ACCESS_TOKEN=your_databand_personal_access_token

# IBM Cloud Object Storage (for log archiving – optional)
COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
COS_API_KEY=your_cos_api_key
COS_INSTANCE_CRN=crn:v1:bluemix:public:cloud-object-storage:global:a/ACCOUNT_ID:RESOURCE_GUID::
COS_BUCKET=databand-logs

# REST API security key for this service
REST_API_KEY=your_rest_api_key

# Alert Notifications (optional)
ALERT_EMAIL=team@example.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXX

# Server
SERVER_URL=http://0.0.0.0:8080
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
