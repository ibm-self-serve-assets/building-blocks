# UDI Document Ingestion — Environment Configuration
#
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# Then run:
#   bash scripts/setup.sh    <- Part 1: register connections + create flow (run once)
#   bash scripts/ingest.sh   <- Part 2: trigger ingestion (run as often as needed)
#
# .env is in .gitignore — never commit it.

# -----------------------------------------------------------------------------
# Required — IBM Cloud
# -----------------------------------------------------------------------------

# IBM Cloud API key
# IBM Cloud -> Manage -> Access (IAM) -> API keys
IBM_CLOUD_API_KEY=

# watsonx.ai project ID
# watsonx console -> project -> Manage -> General -> Project ID
PROJECT_ID=

# -----------------------------------------------------------------------------
# Required — Cloud Object Storage (COS)
#
# RECOMMENDED: HMAC credentials (access_key + secret_key)
#   COS instance -> Service credentials -> Create credential
#   Enable the HMAC option when creating the credential.
#   Copy cos_hmac_keys.access_key_id  -> COS_ACCESS_KEY
#   Copy cos_hmac_keys.secret_access_key -> COS_SECRET_KEY
#
#   To retrieve existing HMAC keys programmatically:
#     curl -H "Authorization: Bearer $TOKEN" \
#       "https://resource-controller.cloud.ibm.com/v2/resource_keys?source_crn=<instance-crn>"
#
# ALTERNATIVE: IAM api_key + resource_instance_id
#   NOTE: IAM mode registers successfully but may fail at UDI runtime.
#   Use HMAC unless you have specific reasons not to.
# -----------------------------------------------------------------------------

COS_BUCKET=
# Direct endpoint URL (optional — if not set, COS_REGION is used to build it)
COS_ENDPOINT=
# Region used to build endpoint when COS_ENDPOINT is not set (e.g. us-south)
COS_REGION=us-south

# HMAC credentials (recommended)
COS_ACCESS_KEY=
COS_SECRET_KEY=

# IAM credentials (alternative — see note above)
# COS_API_KEY=
# COS_INSTANCE_CRN=   <- must be the service instance CRN ending in "::", NOT a bucket CRN

# -----------------------------------------------------------------------------
# Required — OpenSearch
# IBM Lakehouse: host from instance details, username = ibmlhapikey_<your-email>,
#               password = IBM_CLOUD_API_KEY
# -----------------------------------------------------------------------------

OPENSEARCH_HOST=
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# -----------------------------------------------------------------------------
# Optional — Pipeline settings (defaults shown)
# -----------------------------------------------------------------------------

# UDI SDK base URL — do not change unless using a private cloud deployment
WATSONX_URL=https://api.dataplatform.cloud.ibm.com

# UDI environment: cloud-prod | cloud-dev | cloud-test | cpd
WATSONX_ENV=cloud-prod

# Folder path (prefix) inside the COS bucket containing source documents
COLLECTION_NAME=udi_documents

# OpenSearch index to write chunks + embeddings to
INDEX_NAME=udi_opensearch_index

# Text chunking parameters
CHUNK_SIZE=4000
CHUNK_OVERLAP=200

# watsonx embedding model
EMBEDDINGS_MODEL_ID=ibm/slate-30m-english-rtrvr-v2

# Flow name base in watsonx (a timestamp is appended on each setup run to ensure uniqueness)
FLOW_NAME=udi_opensearch_flow
