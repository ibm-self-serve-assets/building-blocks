# ============================================================
# Supply Chain Risk Control Tower — environment configuration
# ============================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# .env is gitignored and must never be committed to source control.
# scripts/setup.sh writes .env automatically when using Terraform.
# ============================================================

# ------------------------------------------------------------
# Confluent Cloud — Kafka cluster credentials
# Created by Terraform (scripts/setup.sh) or manually via
# the Confluent Cloud console under API Keys.
# ------------------------------------------------------------
CONFLUENT_BOOTSTRAP_SERVERS=pkc-xxxxx.us-east-2.aws.confluent.cloud:9092
CONFLUENT_API_KEY=replace-me
CONFLUENT_API_SECRET=replace-me
CONFLUENT_CLIENT_ID=supply-chain-risk-control-tower
CONFLUENT_CONSUMER_GROUP=scrc-risk-engine

# ------------------------------------------------------------
# Confluent Schema Registry
# Required only when running register_schemas or
# enabling schema validation in the risk engine.
# Leave blank if not using Schema Registry.
# ------------------------------------------------------------
SCHEMA_REGISTRY_URL=https://psrc-xxxxx.us-east-2.aws.confluent.cloud
SCHEMA_REGISTRY_API_KEY=replace-me
SCHEMA_REGISTRY_API_SECRET=replace-me

# ------------------------------------------------------------
# Slack alerting (optional)
# Incoming webhook URL from your Slack App configuration.
# Leave blank to disable Slack alerts.
# ------------------------------------------------------------
SLACK_WEBHOOK_URL=

# ------------------------------------------------------------
# OpenSearch / Kibana dashboard (optional)
# Used by any custom consumer or connector that writes risk
# scores to an OpenSearch index.
# ------------------------------------------------------------
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# ------------------------------------------------------------
# IBM watsonx.ai (optional)
# Used by the agent prompt templates in docs/agents/.
# ------------------------------------------------------------
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=
