  <!-- DEVELOPER EDITION SECTION -->
  <developer_edition>
    <overview>
      Developer Edition provides a local development environment for building and
      testing watsonx Orchestrate agents. Voice capabilities require the --with-voice
      flag during installation.
    </overview>

    <installation>
      <prerequisites>
        <prerequisite>Python 3.9 or higher</prerequisite>
        <prerequisite>pip package manager</prerequisite>
        <prerequisite>Internet connection for package downloads</prerequisite>
      </prerequisites>

      <standard_installation>
        <command>pip install ibm-watsonx-orchestrate</command>
        <description>Installs base ADK without voice capabilities</description>
      </standard_installation>

      <voice_enabled_installation>
        <command>pip install ibm-watsonx-orchestrate --with-voice</command>
        <description>Installs ADK with voice agent support</description>
        <important>REQUIRED for voice agent development</important>
      </voice_enabled_installation>

      <verification>
        <command>wxo --version</command>
        <expected_output>Shows installed version number</expected_output>
      </verification>
    </installation>

    <local_development_workflow>
      <step number="1">
        <title>Initialize Project</title>
        <command>wxo init my-voice-agent</command>
        <result>Creates project directory with basic structure</result>
      </step>

      <step number="2">
        <title>Create Agent Locally</title>
        <adk_search>
          <query>agent YAML specification voice_configuration</query>
          <query>local agent development</query>
        </adk_search>
        <action>Create agent YAML file</action>
        <action>Define agent instructions and capabilities</action>
        <action>Reference voice configuration</action>
      </step>

      <step number="3">
        <title>Create Voice Configuration</title>
        <adk_search>
          <query>voice configuration YAML specification</query>
        </adk_search>
        <action>Create voice config YAML file</action>
        <action>Configure STT/TTS providers</action>
        <action>Set audio parameters</action>
      </step>

      <step number="4">
        <title>Test Locally</title>
        <command>wxo agent test --agent-file agent.yaml --voice-config voice-config.yaml</command>
        <description>Runs agent in local test mode</description>
      </step>

      <step number="5">
        <title>Deploy to Cloud</title>
        <command>wxo agent import agent.yaml</command>
        <command>wxo voice-config import voice-config.yaml</command>
        <description>Deploys to watsonx Orchestrate cloud environment</description>
      </step>
    </local_development_workflow>

    <yaml_specifications>
      <overview>
        All watsonx Orchestrate resources are defined using YAML files with a
        consistent structure. Always search ADK documentation for latest specs.
      </overview>

      <common_structure>
        <required_fields>
          <field name="spec_version">
            <description>Specification version</description>
            <value>Always "v1" currently</value>
          </field>
          <field name="kind">
            <description>Resource type</description>
            <values>
              <value>Agent</value>
              <value>VoiceConfiguration</value>
              <value>PhoneConfiguration</value>
              <value>Channel</value>
              <value>Tool</value>
              <value>Connection</value>
            </values>
          </field>
        </required_fields>
      </common_structure>

      <agent_specification>
        <template><![CDATA[
spec_version: v1
kind: Agent
name: my-voice-agent
description: Customer service voice agent
title: Customer Service Assistant

instructions: |
  You are a helpful customer service agent.
  Keep responses concise for voice interactions.
  Always confirm understanding before taking actions.

voice_configuration: my-voice-config  # Reference to voice config

tools:
  - tool-name-1
  - tool-name-2

collaborators:
  - agent-name-1

knowledge_base:
  - kb-name-1
        ]]></template>
        <key_fields>
          <field name="voice_configuration">
            <description>References a VoiceConfiguration resource</description>
            <required>true for voice agents</required>
          </field>
          <field name="instructions">
            <description>Agent behavior and personality</description>
            <voice_optimization>Keep concise, use natural language</voice_optimization>
          </field>
        </key_fields>
      </agent_specification>

      <connection_specification>
        <description>
          Connections store credentials for external services. Never include
          actual credentials in YAML files - use environment variables.
        </description>
        <template><![CDATA[
spec_version: v1
kind: Connection
app_id: my-stt-credentials
environment: draft
type: team
kind: key_value

entries:
  api_key: ${WATSON_STT_API_KEY}
  service_url: ${WATSON_STT_URL}
        ]]></template>
      </connection_specification>
    </yaml_specifications>

    <best_practices>
      <practice>Always use --with-voice flag when installing for voice development</practice>
      <practice>Test locally before deploying to cloud</practice>
      <practice>Use version control (git) for all YAML files</practice>
      <practice>Never commit actual credentials to version control</practice>
      <practice>Use environment variables for sensitive data</practice>
      <practice>Keep YAML files organized in logical directory structure</practice>
      <practice>Document custom configurations in README files</practice>
      <practice>Search ADK docs before creating any YAML specification</practice>
    </best_practices>
  </developer_edition>

  <credential_management>
    <security_principles>
      <principle>NEVER ask users for actual credentials</principle>
      <principle>NEVER store credentials in code or configuration files</principle>
      <principle>ALWAYS use environment variables for sensitive data</principle>
      <principle>ALWAYS create sample/template files only</principle>
    </security_principles>

    <sample_file_creation>
      <description>
        Create .env.example files with placeholder values to show required credentials
      </description>
      <template><![CDATA[
# Watson Speech to Text
WATSON_STT_API_KEY=your_api_key_here
WATSON_STT_URL=https://api.us-south.speech-to-text.watson.cloud.ibm.com

# Watson Text to Speech
WATSON_TTS_API_KEY=your_api_key_here
WATSON_TTS_URL=https://api.us-south.text-to-speech.watson.cloud.ibm.com

# Twilio (for WhatsApp/SMS)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here

# Genesys (for phone)
GENESYS_API_KEY=your_api_key_here
GENESYS_CLIENT_SECRET=your_client_secret_here

# Slack
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your_signing_secret_here
      ]]></template>
    </sample_file_creation>

    <user_instructions>
      <instruction>Copy .env.example to .env</instruction>
      <instruction>Fill in actual credential values in .env</instruction>
      <instruction>Add .env to .gitignore</instruction>
      <instruction>Never commit .env to version control</instruction>
      <instruction>Use different credentials for dev/staging/production</instruction>
    </user_instructions>
  </credential_management>
</voice_agent_configuration>

