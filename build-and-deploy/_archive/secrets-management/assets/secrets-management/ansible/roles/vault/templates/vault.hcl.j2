# Vault Configuration File
# Generated by Ansible

# Storage backend configuration
storage "{{ vault_storage_backend }}" {
{% if vault_storage_backend == 'file' %}
  path = "{{ vault_storage_path }}"
{% elif vault_storage_backend == 'raft' %}
  path = "{{ vault_storage_path }}"
  node_id = "{{ ansible_hostname }}"
{% endif %}
}

# Listener configuration
listener "tcp" {
  address       = "{{ vault_address }}:{{ vault_port }}"
  tls_disable   = {{ vault_tls_disable | lower }}
{% if not vault_tls_disable %}
  tls_cert_file = "{{ vault_tls_cert_file }}"
  tls_key_file  = "{{ vault_tls_key_file }}"
{% endif %}
}

# API address
api_addr = "{{ vault_api_addr }}"

# Cluster address
cluster_addr = "{{ vault_cluster_addr }}"

# UI configuration
ui = {{ vault_ui_enabled | lower }}

# Disable mlock (set to false in production with proper capabilities)
disable_mlock = false

# Log level
log_level = "{{ vault_log_level }}"

# Telemetry (optional)
telemetry {
  disable_hostname = true
}