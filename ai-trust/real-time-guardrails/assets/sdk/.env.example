# Required: IBM Cloud API key + watsonx.governance service instance
WATSONX_APIKEY=
WXG_SERVICE_INSTANCE_ID=

# Optional: watsonx.ai project ID — only needed for the 3 LLM-as-judge metrics
# (Answer Completeness, Conciseness, Tool Call Relevance). If unset, those
# metrics are dropped from the registry; the other 25 metrics work normally.
WXG_PROJECT_ID=

# Optional: override the watsonx.ai endpoint (default: https://us-south.ml.cloud.ibm.com)
# WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Optional: REST server config
# SERVICE_PORT=8090
# DEBUG_MODE=false
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Optional: threshold overrides (any metric, slug-encoded uppercase)
# GUARDRAILS_THRESHOLD_PII_DETECTION=0.7
# GUARDRAILS_THRESHOLD_HAP_HATE_ABUSE_PROFANITY=0.5
# GUARDRAILS_THRESHOLD_FAITHFULNESS=0.15

# Optional: category-shortcut threshold overrides
# GUARDRAILS_THRESHOLD_DEFAULT_SAFETY=0.6
# GUARDRAILS_THRESHOLD_DEFAULT_RAG=0.15
# GUARDRAILS_THRESHOLD_DEFAULT_QUALITY=0.1

# Optional: path to a YAML threshold config file
# GUARDRAILS_CONFIG_PATH=./thresholds.yaml
