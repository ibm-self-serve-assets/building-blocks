# Sample env-var threshold deployment. Source this file before starting the
# REST server: `set -a && source .env.thresholds && set +a && real-time-guardrails serve`

# Category shortcuts
GUARDRAILS_THRESHOLD_DEFAULT_SAFETY=0.6
GUARDRAILS_THRESHOLD_DEFAULT_RAG=0.15
GUARDRAILS_THRESHOLD_DEFAULT_QUALITY=0.1

# Per-metric overrides (uppercase, non-alphanumerics → underscore)
GUARDRAILS_THRESHOLD_PII_DETECTION=0.7
GUARDRAILS_THRESHOLD_HAP_HATE_ABUSE_PROFANITY=0.5
GUARDRAILS_THRESHOLD_JAILBREAK_DETECTION=0.5
GUARDRAILS_THRESHOLD_FAITHFULNESS=0.2
