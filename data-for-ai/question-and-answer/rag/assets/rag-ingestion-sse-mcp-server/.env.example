# =============================================================================
# RAG Ingestion MCP Server - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# This server ingests documents from IBM Cloud Object Storage (COS) or local
# directories into vector databases (OpenSearch or Milvus) for RAG applications

# =============================================================================
# Server Configuration
# =============================================================================
# Host and port for the MCP server
HOST=0.0.0.0
PORT=8080

# Server identification
SERVER_NAME=rag-ingestion-mcp
SERVER_VERSION=1.0.0

# Server description (optional)
SERVER_DESCRIPTION=Base MCP Server for Data for AI Building Block (with RAG ingestion)

# Environment: development, staging, or production
ENVIRONMENT=development

# Optional: Public base URL for the server (used for CORS/security)
PUBLIC_BASE_URL=

# Optional: Comma-separated list of allowed hosts (overrides default)
ALLOWED_HOSTS=

# Optional: Comma-separated list of allowed origins (overrides default)
ALLOWED_ORIGINS=

# Optional: Bearer token for API authentication (leave empty to disable)
APP_BEARER_TOKEN=

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# =============================================================================
# IBM Cloud Object Storage (COS) Configuration
# =============================================================================
# Source for document ingestion - Required for ingest_from_cos tool
# Get these values from your IBM Cloud Object Storage instance

# COS endpoint URL (region-specific)
COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud

# COS API key (IAM API key with access to the bucket)
COS_API_KEY=your_cos_api_key_here

# COS instance CRN (Cloud Resource Name)
# Format: crn:v1:bluemix:public:cloud-object-storage:global:a/<account_id>:<instance_id>::
COS_INSTANCE_CRN=crn:v1:bluemix:public:cloud-object-storage:global:a/your_account_id:your_instance_id::

# Default bucket name for ingestion
COS_BUCKET=your_bucket_name

# Default prefix/path within the bucket (e.g., "ingest" or "documents/")
COS_PREFIX=ingest

# =============================================================================
# IBM Watsonx Embeddings Configuration (REQUIRED)
# =============================================================================
# Used to generate embeddings for document chunks
# Get these values from your IBM Watsonx AI project

# Watsonx API endpoint URL
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Watsonx API key (IAM API key with access to Watsonx)
WATSONX_API_KEY=your_watsonx_api_key_here

# Watsonx project ID (from your Watsonx project)
WATSONX_PROJECT_ID=your_project_id_here

# Embedding model ID (must be available in your Watsonx instance)
# Recommended: intfloat/multilingual-e5-large
EMBEDDING_MODEL_ID=intfloat/multilingual-e5-large

# =============================================================================
# Document Chunking Configuration
# =============================================================================
# Controls how documents are split into chunks for embedding

# Size of each text chunk in characters
CHUNK_SIZE=256

# Overlap between consecutive chunks in characters
CHUNK_OVERLAP=128

# Whether to include all HTML tags when processing HTML files (true/false)
INCLUDE_ALL_HTML_TAGS=false

# =============================================================================
# Vector Database Selection (REQUIRED)
# =============================================================================
# Choose which vector database to use: opensearch or milvus
VECTOR_DB_TYPE=opensearch

# =============================================================================
# OpenSearch Configuration (REQUIRED if VECTOR_DB_TYPE=opensearch)
# =============================================================================
# OpenSearch cluster connection details

# OpenSearch host (hostname or IP address)
OPENSEARCH_HOST=your_opensearch_host_here

# OpenSearch port (default: 9200)
OPENSEARCH_PORT=9200

# OpenSearch username for authentication
OPENSEARCH_USERNAME=your_opensearch_username

# OpenSearch password for authentication
OPENSEARCH_PASSWORD=your_opensearch_password

# Default index name for document storage
OPENSEARCH_INDEX=rag-index

# Use SSL/TLS for OpenSearch connection (true/false)
OPENSEARCH_USE_SSL=true

# =============================================================================
# Milvus Configuration (REQUIRED if VECTOR_DB_TYPE=milvus)
# =============================================================================
# Milvus vector database connection details

# Milvus host (hostname or IP address)
MILVUS_HOST=

# Milvus port (default: 19530)
MILVUS_PORT=19530

# Milvus username for authentication (leave empty if not required)
MILVUS_USER=

# Milvus password for authentication (leave empty if not required)
MILVUS_PASSWORD=

# Use secure connection (TLS) for Milvus (true/false)
MILVUS_SECURE=false

# Default collection name for document storage
MILVUS_COLLECTION=rag_collection

# Enable hybrid search (BM25 + dense vector) (true/false)
# If true, creates schema with both dense and sparse vectors
MILVUS_HYBRID_SEARCH=false

# Use bulk ingestion for Milvus (true/false)
# If true, uses RemoteBulkWriter for efficient bulk import
MILVUS_USE_BULK_INGESTION=false

# =============================================================================
# Milvus Bulk Writer Configuration (REQUIRED if VECTOR_DB_TYPE=milvus)
# =============================================================================
# Remote storage (S3/COS) configuration for Milvus bulk import
# Required for efficient bulk ingestion into Milvus

# Remote path for bulk import files (e.g., "bulk-import/")
MILVUS_BULK_REMOTE_PATH=

# COS/S3 endpoint for bulk import storage
MILVUS_BULK_COS_ENDPOINT=

# COS/S3 access key for bulk import storage
MILVUS_BULK_COS_ACCESS_KEY=

# COS/S3 secret key for bulk import storage
MILVUS_BULK_COS_SECRET_KEY=

# COS/S3 bucket name for bulk import files
MILVUS_BULK_COS_BUCKET=

# COS/S3 region for bulk import storage
MILVUS_BULK_COS_REGION=

# Set to true if using IBM Cloud Object Storage (true/false)
MILVUS_BULK_COS_IS_IBM=true